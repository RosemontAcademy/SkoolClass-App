{
  "name": "skoolclass-app",
  "productName": "SkoolClass",
  "version": "1.0.2",
  "description": "SkoolClass desktop shell — Rosemont Academy staff console",
  "main": "src/main.js",
  "author": "Rosemont Academy",
  "license": "UNLICENSED",
  "repository": "github:RosemontAcademy/SkoolClass-App",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/make-ico.mjs",
    "dist": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "kr.rosemont.skoolclass",
    "productName": "SkoolClass",
    "artifactName": "SkoolClass-Setup-${version}.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/ico/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "SkoolClass",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "RosemontAcademy",
      "repo": "SkoolClass-App"
    }
  }
}
